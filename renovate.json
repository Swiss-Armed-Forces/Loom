{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Comprehensive Renovate configuration for Loom - a multi-technology project with Frontend (TypeScript/React), Backend (Python/Poetry), Docker, and Helm",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases",
    "security:openssf-scorecard",
    "workarounds:all"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on sunday"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "branchPrefix": "renovate/",
  "labels": ["dependencies", "renovate"],
  "enabledManagers": [
    "npm",
    "poetry",
    "dockerfile",
    "helm-values",
    "helmv3",
    "gitlabci",
    "nix",
    "custom.regex"
  ],
  "poetry": {
    "versioning": "pep440"
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "minimumReleaseAge": null,
    "prCreation": "immediate",
    "labels": ["security", "vulnerability"],
    "groupName": null,
    "groupSlug": null
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"],
    "commitMessageAction": "lock file maintenance",
    "branchTopic": "lock-file-maintenance"
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchFileNames": ["Frontend/**"],
      "groupName": "Frontend Dependencies",
      "matchDepTypes": ["dependencies", "devDependencies"],
      "prPriority": 5,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchManagers": ["poetry"],
      "matchFileNames": ["backend/**", "integrationtest/**"],
      "groupName": "Backend Dependencies",
      "prPriority": 4,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchManagers": ["poetry"],
      "matchFileNames": ["pyproject.toml"],
      "groupName": "Root Dev Dependencies",
      "prPriority": 3,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchManagers": ["poetry"],
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile", "gitlabci"],
      "groupName": "Docker images",
      "prPriority": 3,
      "matchUpdateTypes": ["minor", "patch", "digest"]
    },
    {
      "matchManagers": ["dockerfile"],
      "matchDepNames": ["docker.io/chrislusf/seaweedfs"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)_(?<compatibility>full)$"
    },
    {
      "matchFileNames": ["backend/common/pyproject.toml"],
      "postUpgradeTasks": {
        "commands": [
          "poetry lock --no-update --directory backend/api",
          "poetry lock --no-update --directory backend/worker",
          "poetry lock --no-update --directory backend/crawler",
          "poetry lock --no-update"
        ],
        "fileFilters": [
          "backend/api/poetry.lock",
          "backend/worker/poetry.lock",
          "backend/crawler/poetry.lock",
          "poetry.lock"
        ],
        "executionMode": "update"
      }
    },
    {
      "matchUpdateTypes": ["major"],
      "prPriority": 10,
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchManagers": ["nix"],
      "groupName": "Nix Development Environment",
      "matchFileNames": ["devenv.yaml", "devenv.nix", "devenv.lock"],
      "prPriority": 2,
      "schedule": ["before 6am on sunday"],
      "labels": ["nix", "devenv"]
    },
    {
      "matchManagers": ["nix"],
      "matchDepNames": [
        "nixpkgs",
        "nixpkgs-stable",
        "nixpkgs-unstable",
        "nixpkgs-24-11"
      ],
      "groupName": "Nix Package Channels",
      "prPriority": 1,
      "schedule": ["before 6am on the first day of the month"],
      "labels": ["nix", "nixpkgs"]
    },
    {
      "matchManagers": ["nix"],
      "matchDepNames": ["devenv", "git-hooks"],
      "groupName": "Nix Development Tools",
      "prPriority": 3,
      "schedule": ["before 6am on sunday"],
      "labels": ["nix", "dev-tools"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update package manager versions in package.json",
      "managerFilePatterns": ["/(^|/)package\\.json$/"],
      "matchStrings": [
        "\"packageManager\":\\s*\"(?<depName>pnpm)@(?<currentValue>\\S+)\""
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    }
  ],
  "hostRules": [
    {
      "matchHost": "registry.npmjs.org",
      "concurrentRequestLimit": 10
    },
    {
      "matchHost": "pypi.org",
      "concurrentRequestLimit": 10
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/logs/**",
    "**/log/**",
    "**/out/**"
  ],
  "allowedCommands": [
    "^poetry lock --no-update"
  ],
  "rebaseWhen": "behind-base-branch",
  "automergeSchedule": ["before 6am"],
  "platformAutomerge": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "dependencyDashboardApproval": false,
  "dependencyDashboardAutoclose": true,
  "commitBodyTable": true,
  "prBodyTemplate": "{{{header}}}{{{table}}}{{{notes}}}{{{changelogs}}}{{{controls}}}{{{footer}}}"
}
